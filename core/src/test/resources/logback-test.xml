<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%13([%thread]) %-5level %20logger{0} - %X{taskId}%X{stepId}%msg%n</pattern>
        </encoder>
    </appender>



    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
